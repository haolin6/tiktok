{
  "name": "@live-auction/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npm run build -w @live-auction/shared && tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "npm run build -w @live-auction/shared && npm run db:migrate && npm run db:seed && vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "demo:concurrency": "tsx src/scripts/simulate-concurrency.ts",
    "demo:realtime-fanout": "tsx src/scripts/simulate-realtime-fanout.ts"
  },
  "dependencies": {
    "@live-auction/shared": "file:../../packages/shared",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "mysql2": "^3.14.1",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "socket.io-client": "^4.8.3"
  }
}
